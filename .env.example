# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tamp"

# ── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="replace-with-a-long-random-string"
API_BASE_URL="http://localhost:3000"

# ── API server ────────────────────────────────────────────────────────────────
PORT=3000
ALLOWED_ORIGINS="http://localhost:8081"

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Local dev (Azurite running on localhost):
AZURE_STORAGE_CONNECTION_STRING="UseDevelopmentStorage=true"
# Inside docker-compose, DATABASE_URL and AZURE_STORAGE_CONNECTION_STRING are
# overridden by the environment: block in docker-compose.yml.
